{
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "workspace": "/data/.openclaw/sophia",
      "memorySearch": {
        "provider": "openai",
        "model": "text-embedding-3-small"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "2h",
        "target": "whatsapp",
        "activeHours": {
          "start": "08:00",
          "end": "23:00",
          "timezone": "Europe/Rome"
        }
      },
      "thinkingDefault": "adaptive",
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      },
      "userTimezone": "Europe/Rome"
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Sophia",
          "theme": "AI companion"
        }
      }
    ]
  },
  "tools": {
    "web": {
      "search": {
        "enabled": true
      },
      "fetch": {
        "enabled": true
      }
    },
    "media": {
      "audio": {
        "enabled": true,
        "models": [
          {
            "provider": "deepgram",
            "model": "nova-3"
          }
        ],
        "providerOptions": {
          "deepgram": {
            "detect_language": true,
            "punctuate": true,
            "smart_format": true
          }
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "cron": {
    "enabled": true
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing",
      "allowFrom": ["+15555550123"],
      "groupPolicy": "allowlist",
      "debounceMs": 0,
      "mediaMaxMb": 50
    },
    "discord": {
      "enabled": true,
      "groupPolicy": "allowlist",
      "dmPolicy": "pairing",
      "guilds": {
        "1397938267961430097": {
          "requireMention": false,
          "channels": {
            "1397938269219586225": {
              "requireMention": false
            }
          }
        }
      },
      "voice": {
        "enabled": true,
        "daveEncryption": true,
        "decryptionFailureTolerance": 24,
        "tts": {
          "provider": "elevenlabs",
          "providers": {
            "elevenlabs": {
              "voiceId": "aFueGIISJUmscc05ZNfD",
              "modelId": "eleven_v3",
              "voiceSettings": {
                "stability": 0.5,
                "similarityBoost": 0.8,
                "style": 0.1,
                "useSpeakerBoost": true,
                "speed": 0.95
              }
            }
          }
        }
      },
      "inboundWorker": {
        "runTimeoutMs": 1800000
      },
      "eventQueue": {
        "listenerTimeout": 120000
      },
      "commands": {
        "native": true
      }
    }
  },
  "messages": {
    "tts": {
      "auto": "off",
      "provider": "elevenlabs",
      "providers": {
        "elevenlabs": {
          "voiceId": "aFueGIISJUmscc05ZNfD",
          "modelId": "eleven_v3",
          "voiceSettings": {
            "stability": 0.5,
            "similarityBoost": 0.8,
            "style": 0.1,
            "useSpeakerBoost": true,
            "speed": 0.95
          }
        }
      }
    }
  },
  "talk": {
    "provider": "elevenlabs",
    "providers": {
      "elevenlabs": {
        "voiceId": "aFueGIISJUmscc05ZNfD"
      }
    }
  }
}
