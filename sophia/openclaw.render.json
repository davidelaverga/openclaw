{
  "env": {
    "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}",
    "OPENAI_API_KEY": "${OPENAI_API_KEY}",
    "DEEPGRAM_API_KEY": "${DEEPGRAM_API_KEY}",
    "ELEVENLABS_API_KEY": "${ELEVENLABS_API_KEY}",
    "LLAMA_CLOUD_API_KEY": "${LLAMA_CLOUD_API_KEY}"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-sonnet-4-6"
      },
      "imageGenerationModel": {
        "primary": "openai/gpt-image-1.5"
      },
      "workspace": "/data/.openclaw/sophia",
      "memorySearch": {
        "provider": "openai",
        "model": "text-embedding-3-small"
      },
      "heartbeat": {
        "every": "2h",
        "target": "whatsapp"
      }
    },
    "list": [
      {
        "id": "main",
        "identity": {
          "name": "Sophia",
          "theme": "AI companion"
        }
      }
    ]
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "headless": true,
    "noSandbox": true
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "language": "multi",
        "providerOptions": {
          "deepgram": {
            "smart_format": true
          }
        },
        "models": [
          {
            "provider": "deepgram",
            "model": "nova-3"
          }
        ]
      }
    }
  },
  "messages": {
    "tts": {
      "auto": "inbound",
      "provider": "elevenlabs",
      "strictProvider": true,
      "elevenlabs": {
        "voiceId": "aFueGIISJUmscc05ZNfD",
        "modelId": "eleven_multilingual_v2",
        "voiceSettings": {
          "speed": 0.92,
          "stability": 0.6,
          "similarityBoost": 0.82,
          "style": 0.0
        }
      }
    }
  },
  "cron": {
    "enabled": true
  },
  "logging": {
    "level": "debug",
    "consoleLevel": "debug",
    "consoleStyle": "json"
  },
  "diagnostics": {
    "cacheTrace": {
      "enabled": true,
      "filePath": "/data/.openclaw/logs/cache-trace.jsonl",
      "includeMessages": true,
      "includePrompt": true,
      "includeSystem": true
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "bootstrap-extra-files": {
          "enabled": true,
          "paths": ["tone_skills.md"]
        }
      }
    }
  },
  "plugins": {
    "enabled": true,
    "entries": {
      "prompt-observer": {
        "enabled": true,
        "config": {
          "mode": "full",
          "includeSystemPrompt": true,
          "includePrompt": true,
          "includeHistoryMessages": true,
          "includeLlmOutput": true,
          "includeToolResults": true,
          "includeBootstrapFiles": true,
          "redactSensitive": true,
          "maxCharsPerField": 8000,
          "maxHistoryMessages": 12,
          "toolNames": [
            "memory_search",
            "memory_get",
            "web_search",
            "web_fetch",
            "check_assumptions",
            "steelman",
            "find_analogy",
            "decompose_claim",
            "inhabit_scene",
            "perspective_shift",
            "name_the_state"
          ]
        }
      },
      "sophia-document": {
        "enabled": true,
        "config": {
          "tier": "cost_effective",
          "version": "latest",
          "pollIntervalMs": 2000,
          "pollTimeoutMs": 45000,
          "maxChars": 48000,
          "alwaysParseExtensions": [".ppt", ".pptx", ".xls", ".xlsx"],
          "fallbackParseExtensions": [".pdf", ".doc", ".docx"]
        }
      },
      "sophia-thinking-tools": {
        "enabled": true,
        "config": {
          "specialist": {
            "primary": {
              "provider": "openai",
              "model": "gpt-5.4",
              "reasoningEffort": "high",
              "timeoutMs": 12000,
              "maxOutputTokens": 500
            },
            "fallback": {
              "provider": "anthropic",
              "model": "claude-opus-4-6",
              "timeoutMs": 12000,
              "maxOutputTokens": 400
            }
          }
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "controlUi": {
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "selfChatMode": false,
      "dmPolicy": "allowlist",
      "allowFrom": ["+393894991082"],
      "groupPolicy": "allowlist",
      "ackReaction": {
        "emoji": "💙",
        "direct": true,
        "group": "mentions"
      }
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "headless": true,
    "noSandbox": true
  }
}
